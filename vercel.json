{
  "redirects": [
    { "source": "/events", "destination": "/dashboard/events", "permanent": true },
    { "source": "/finance", "destination": "/dashboard/finance", "permanent": true },
    { "source": "/chat", "destination": "/dashboard/chat", "permanent": true },
    { "source": "/calendar", "destination": "/dashboard/calendar", "permanent": true },
    { "source": "/settings", "destination": "/dashboard/settings", "permanent": true },
    { "source": "/audience", "destination": "/dashboard/audience", "permanent": true },
    { "source": "/insights", "destination": "/dashboard/promo-insights", "permanent": true },
    { "source": "/discover", "destination": "/dashboard/discover", "permanent": true },
    { "source": "/promo", "destination": "/dashboard/marketing", "permanent": true },
    { "source": "/money", "destination": "/dashboard/finance", "permanent": true },
    { "source": "/venues", "destination": "/dashboard/venues", "permanent": true },
    { "source": "/artists", "destination": "/dashboard/artists", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2|png|jpg|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/cleanup-pending-tickets",
      "schedule": "*/15 * * * *"
    }
  ]
}
